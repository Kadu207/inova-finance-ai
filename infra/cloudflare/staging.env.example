# Cloudflare Staging — substituir placeholders antes do deploy
# Agent 06 + Agent 40 Release Gate

# Hyperdrive (Dashboard CF → Hyperdrive → Create)
HYPERDRIVE_ID=replace-with-hyperdrive-id

# KV Sessions
SESSIONS_KV_ID=replace-with-kv-id
SESSIONS_KV_PREVIEW=replace-with-kv-preview-id

# Queues
EVENTS_QUEUE_NAME=inova-events-staging

# Secrets (wrangler secret put — NUNCA commitar valores reais)
# JWT_SECRET=
# VPS_WEBHOOK_SECRET=
# OPENROUTER_API_KEY=

# Domínio staging
STAGING_HOST=staging.inovafinanceai.inovatitech.com.br

# VPS tunnel upstream (Hetzner)
VPS_HEALTH_URL=https://vps-staging.inovatitech.com.br/health
N8N_HEALTH_URL=https://n8n-staging.inovatitech.com.br/healthz
CHATWOOT_HEALTH_URL=https://chat-staging.inovatitech.com.br/api
