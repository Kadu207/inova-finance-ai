{
  "name": "inova-finance-ai",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:contract": "turbo run test:contract",
    "test:e2e": "playwright test",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @inova/db generate",
    "db:migrate": "pnpm --filter @inova/db migrate",
    "db:push": "pnpm --filter @inova/db push",
    "dev:local": "bash scripts/dev-local.sh start",
    "dev:local:stop": "bash scripts/dev-local.sh stop",
    "dev:local:status": "bash scripts/dev-local.sh status",
    "dev:local:restart": "bash scripts/dev-local.sh restart"
  },
  "devDependencies": {
    "@playwright/test": "1.49.1",
    "turbo": "2.3.3",
    "typescript": "5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
