{
  "name": "@inova/app-api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx src/dev-node.ts",
    "dev:cf": "wrangler dev --port 8810",
    "build": "wrangler deploy --dry-run",
    "deploy": "wrangler deploy",
    "deploy:staging": "wrangler deploy --env staging",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@inova/config": "workspace:*",
    "@inova/events": "workspace:*",
    "hono": "4.7.9"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260615.1",
    "tsx": "4.19.2",
    "typescript": "5.7.2",
    "vitest": "2.1.8",
    "wrangler": "4.100.0"
  }
}
